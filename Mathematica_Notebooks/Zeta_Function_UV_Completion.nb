(* ====================================================== *)
(* Zeta_Function_UV_Completion.nb                         *)
(* Exact zeta-function regularisation and UV finiteness   *)
(* Matches Section 10 exactly                             *)
(* ====================================================== *)

(* Master operator eigenvalues *)
λN = N Δλ + c;

(* Zeta function *)
ζ[s_] := Sum[λN^-s, {N, -∞, ∞}];

(* Analytic continuation *)
ζAnalytic = HurwitzZeta[s, c/Δλ] + HurwitzZeta[s, 1 - c/Δλ];

(* Heat-kernel expansion with multifractal measure *)
TrExp[-t D^2] = Sum[Exp[-t λN^2], {N}] /. 
  Sum → Integrate[wN[ℓ] ℓ^(dN[ℓ]-4) t^(-dN[ℓ]/2) dμ];

(* UV behaviour *)
ShortDistanceLimit = Limit[TrExp[-t D^2], ℓ → 0];
(* dN[ℓ] → 2 makes the integrand ~ ℓ^{-2}, which is integrable *)

Print["Zeta-function regularisation complete - UV finite at all scales."]
