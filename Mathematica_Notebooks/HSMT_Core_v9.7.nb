Gcat = 0.91596559417721901505460351493238411`; (* Catalan's constant *)
α = π + Gcat;
σ0 = Sqrt[2]/4;
ℓ0 = 10^-3;  (* Reference length scale *)

(* Generation-dependent slopes fixed by shape-invariance *)
κ0 = 3/10; b0 = 4/5; c0 = 3/2;
κ[n_] := κ0 + (4 π/3) n;
b[n_] := b0 + 2 Sqrt[3] n;
c[n_] := c0 + (π + E)/2 n;

A = α (4 π/3);
B = α 2 Sqrt[3];
m0 = α (π + E)/2;

