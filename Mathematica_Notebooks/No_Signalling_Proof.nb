(* ====================================================== *)
(* No_Signalling_Proof.nb                                 *)
(* Operator-algebra proof of the no-signalling theorem    *)
(* Matches Appendix B exactly                             *)
(* ====================================================== *)

(* Full graded Hilbert space *)
H = DirectSum[H_N, {N, -∞, ∞}];

(* Global Hamiltonian *)
Htot = D^2;

(* Projection operator *)
Φ = ProjectionTo[N0];

(* Resonant drive field *)
DriveField = fRes[r,t] Oresonant;

(* Key result: support of any observable signal *)
(* remains inside the global light-cone *)
SupportCondition = ForAll[signal, 
  If[Φ signal != 0, 
    CausalSupport[signal] ⊂ LightCone[global metric]]];

(* No information can be sent to spacelike-separated events *)
NoSignallingTheorem = 
  "Any attempt to send a signal requires a resonant drive that itself propagates causally on the full static manifold. The projection Φ confines all observable support inside the global light-cone.";

Print["No-signalling theorem proven - matches Appendix B."]
