(* ====================================================== *)
(* SM_Overlap_Integrals.nb *)
(* Explicit overlap integrals for Standard Model parameters *)
(* Consistent with Section "Emergence of the Standard Model Parameters" *)
(* Vincent Mark Garrett with Grok 4.2 - May 2026 *)
(* ====================================================== *)

(* Canonical parameters *)
σ0 = 0.35; α = 1/(Sqrt[2]*σ0); Δ = 1.1*^11; β = 1; ℓ0 = 10^-3; λ = 1;

(* Exact radial wavefunctions in N = -1 shell *)
ψfi[ρ_, i_, f_] := Nfi * Exp[-α ρ/2] * (1 + Exp[2 α ρ])^-κ *
                   Hypergeometric2F1[-(i-1), b, c, -Exp[2 α ρ]] * χf;

(* Overlap integral for Yukawa matrix elements *)
Yij[f_, i_, j_] := Integrate[
  Conjugate[ψfi[ρ, i, f]] * ψfi[ρ, j, f] *
  w[-1][ℓ] * ℓ^(d[-1][ℓ] - 4),
  {ρ, -∞, ∞}];

(* Higgs vev from geometric projection *)
vev = λ * Δλ * w[-1][ℓHiggs];

(* Fermion masses *)
m[f_, k_] := Ykk[f, k] * vev;

(* Example: Electron *)
ye = Yij["e", 1, 1];
me = ye * vev;

Print["Electron Yukawa (computed): ", ye];
Print["Computed electron mass: ", me, " MeV"];
Print["Target (CODATA): 0.511 MeV"];

(* Gauge couplings and other parameters *)
Print["Gauge couplings g_i and θ_QCD are likewise obtained from"];
Print["analogous overlap amplitudes between gauge sectors."];
Print["CKM and PMNS matrices require diagonalization of the full Yukawa matrices."];

Print["All 19 SM parameters are proposed to emerge from the same overlap integrals."];
Print["Results remain under active numerical investigation."];
